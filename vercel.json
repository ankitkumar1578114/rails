{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/status",
      "dest": "api/index.py"
    },
    {
      "src": "/v2/status",
      "dest": "api/index.py"
    },
    {
      "src": "/stations",
      "dest": "api/index.py"
    },
    {
      "src": "/trains/between",
      "dest": "api/index.py"
    },
    {
      "src": "/trains",
      "dest": "api/index.py"
    },
    {
      "src": "/",
      "dest": "api/index.py"
    }
  ]
}
